@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Quản Lý Tin Tức Du Lịch";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
<link rel="stylesheet" href="@Url.Content("~/Views/Admin/admin.css")">

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card card-custom p-3 bg-white border-start border-warning border-4">
            <div class="text-muted small text-uppercase fw-bold">Tổng số bài viết</div>
            <div class="h3 fw-bold mt-1 text-dark">2</div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-end align-items-center mb-4">
    <button class="btn btn-warning fw-bold px-4" onclick="openCreateModal()">
        <i class="fa-solid fa-plus me-2"></i>Thêm tin tức
    </button>
</div>

<div class="card card-custom shadow-sm border-0">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table id="newsTable" class="table table-hover align-middle mb-0" style="width:100%">
                <thead class="table-light">
                    <tr>
                        <th style="width: 80px;">Hình ảnh</th>
                        <th>Tiêu đề bài viết</th>
                        <th style="width: 120px;">Ngày đăng</th>
                        <th style="width: 100px;">Lượt xem</th>
                        <th class="text-end" style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Dòng 1: Tin tức dạng SỰ KIỆN (Có ngày bắt đầu/kết thúc) -->
                    <tr>
                        <td>
                            <img src="/UploadedFiles/sample1.jpg" class="rounded" style="width: 60px; height: 40px; object-fit: cover;" onerror="this.src='https://placehold.co/60x40?text=No+Image'" />
                        </td>
                        <td>
                            <div class="fw-bold text-dark text-wrap">Khai mạc tuần lễ văn hóa ẩm thực và du lịch biển Ba Động 2026</div>
                            <small class="text-muted text-wrap d-block mt-1">Chuỗi hoạt động văn hóa thể thao và hội chợ thương mại đặc sắc chính thức khai mạc...</small>
                        </td>
                        <td>01/06/2026</td>
                        <td><span class="badge bg-secondary px-2 py-1.5">1,420</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="openEditModal(1, 'Khai mạc tuần lễ văn hóa ẩm thực và du lịch biển Ba Động 2026', 'Chuỗi hoạt động văn hóa thể thao và hội chợ thương mại đặc sắc chính thức khai mạc...', '/UploadedFiles/sample1.jpg', '2026-06-01', '2026-06-07', 'Nội dung chi tiết đầy đủ của bài viết về tuần lễ văn hóa ẩm thực và du lịch biển Ba Động năm 2026...')"><i class="fa-solid fa-pen"></i> Sửa</button>
                            <button class="btn btn-sm btn-outline-danger" onclick="confirmDelete(1)"><i class="fa-solid fa-trash"></i> Xóa</button>
                        </td>
                    </tr>
                    <!-- Dòng 2: Tin tức THƯỜNG (Bỏ trống ngày bắt đầu/kết thúc) -->
                    <tr>
                        <td>
                            <img src="/UploadedFiles/sample2.jpg" class="rounded" style="width: 60px; height: 40px; object-fit: cover;" onerror="this.src='https://placehold.co/60x40?text=No+Image'" />
                        </td>
                        <td>
                            <div class="fw-bold text-dark text-wrap">Top 5 món ngon hải sản độc lạ phải thử khi ghé thăm Duyên Hải</div>
                            <small class="text-muted text-wrap d-block mt-1">Khám phá danh sách những đặc sản nức tiếng vùng biển duyên hải từ chù ụ rang me...</small>
                        </td>
                        <td>28/05/2026</td>
                        <td><span class="badge bg-secondary px-2 py-1.5">950</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="openEditModal(2, 'Top 5 món ngon hải sản độc lạ phải thử khi ghé thăm Duyên Hải', 'Khám phá danh sách những đặc sản nức tiếng vùng biển duyên hải từ chù ụ rang me...', '/UploadedFiles/sample2.jpg', '', '', 'Nội dung chi tiết cẩm nang ăn uống ẩm thực tại vùng biển Duyên Hải với các món hải sản độc lạ...')"><i class="fa-solid fa-pen"></i> Sửa</button>
                            <button class="btn btn-sm btn-outline-danger" onclick="confirmDelete(2)"><i class="fa-solid fa-trash"></i> Xóa</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Thêm/Sửa Tin Tức -->
<div class="modal fade" id="newsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold text-uppercase" id="modalTitle">Thêm Bài Viết Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="newsForm" enctype="multipart/form-data">
                <div class="modal-body">
                    <input type="hidden" id="newsId" name="Id" value="" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tiêu đề bài viết <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="newsTitle" name="Title" required placeholder="Nhập tiêu đề hấp dẫn để quảng bá du lịch...">
                    </div>

                    <!-- Cập nhật: Thêm chữ (Tùy chọn) và không có thuộc tính required -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ngày bắt đầu sự kiện</label>
                            <input type="date" class="form-control" id="newsStartDate" name="StartDate">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ngày kết thúc sự kiện</label>
                            <input type="date" class="form-control" id="newsEndDate" name="EndDate">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Hình ảnh <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" id="newsImageFile" name="ImageFile" accept="image/*" onchange="previewImage(this)">

                        <div class="preview-img-container mt-2" id="previewContainer" style="display: none;">
                            <small class="text-muted d-block mb-1">Ảnh hiển thị:</small>
                            <img id="imagePreview" src="" alt="Xem trước ảnh" style="max-height: 150px; object-fit: cover;" class="rounded border">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mô tả tóm tắt nội dung <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="newsSummary" name="Summary" rows="3" required placeholder="Viết một đoạn tóm tắt ngắn hiển thị ngoài danh sách bài viết..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nội dung chi tiết bài viết <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="newsContent" name="Content" rows="7" required placeholder="Nhập toàn bộ nội dung chi tiết bài viết tại đây..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-warning fw-bold text-white px-4">Lưu lại</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        var bootstrapModal;
        $(document).ready(function () {
            if (document.getElementById('newsModal')) {
                bootstrapModal = new bootstrap.Modal(document.getElementById('newsModal'));
            }

            if ($('#newsTable').length > 0) {
                $('#newsTable').DataTable({
                    "language": {
                        "lengthMenu": "Hiển thị _MENU_ bài viết",
                        "zeroRecords": "Không tìm thấy bài viết nào phù hợp",
                        "info": "Hiển thị từ _START_ đến _END_ trong tổng số _TOTAL_ bài",
                        "infoEmpty": "Không có dữ liệu",
                        "infoFiltered": "(đã lọc từ _MAX_ mục)",
                        "search": "Tìm kiếm nhanh:",
                        "paginate": { "first": "Đầu", "last": "Cuối", "next": "Sau", "previous": "Trước" }
                    },
                    "ordering": true,
                    "columnDefs": [
                        { "orderable": false, "targets": [0, 4] }
                    ]
                });
            }

            $('#newsForm').on('submit', function (e) {
                e.preventDefault();
                var formData = new FormData(this);
                var isEdit = $('#newsId').val() !== "";

                Swal.fire({
                    title: 'Đang xử lý...',
                    text: 'Vui lòng chờ trong giây lát.',
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading(); }
                });

                $.ajax({
                    url: '@Url.Action("SaveNews", "Admin")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        if (bootstrapModal) bootstrapModal.hide();
                        var alertTitle = isEdit ? 'Cập nhật thành công!' : 'Thêm mới thành công!';
                        var alertText = isEdit ? 'Thông tin bài viết đã được cập nhật.' : 'Bài viết mới đã được đăng tải hệ thống.';

                        Swal.fire({ title: alertTitle, text: alertText, icon: 'success', confirmButtonColor: '#ffc107' }).then(() => {
                            window.location.reload();
                        });
                    },
                    error: function () {
                        Swal.fire('Lỗi hệ thống!', 'Không thể lưu dữ liệu.', 'error');
                    }
                });
            });
        });

        function openCreateModal() {
            $('#newsForm')[0].reset();
            $('#newsId').val('');
            $('#newsImageFile').attr('required', true);
            $('#previewContainer').hide();

            // Làm rỗng trường dữ liệu tùy chọn
            $('#newsStartDate').val('');
            $('#newsEndDate').val('');
            $('#newsContent').val('');

            $('#modalTitle').text('Thêm Bài Viết Mới');
            if (bootstrapModal) bootstrapModal.show();
        }

        function openEditModal(id, title, summary, currentImgUrl, startDate, endDate, content) {
            $('#newsForm')[0].reset();
            $('#newsId').val(id);
            $('#newsTitle').val(title);
            $('#newsSummary').val(summary);
            $('#newsImageFile').attr('required', false);

            // Gán dữ liệu ngày (nếu không có, giá trị truyền vào là chuỗi rỗng '' và ô input date tự hiểu để trống)
            $('#newsStartDate').val(startDate ? startDate : '');
            $('#newsEndDate').val(endDate ? endDate : '');
            $('#newsContent').val(content);

            if (currentImgUrl) {
                $('#imagePreview').attr('src', currentImgUrl);
                $('#previewContainer').show();
            } else {
                $('#previewContainer').hide();
            }

            $('#modalTitle').text('CẬP NHẬT BÀI VIẾT');
            if (bootstrapModal) bootstrapModal.show();
        }

        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imagePreview').attr('src', e.target.result);
                    $('#previewContainer').show();
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function confirmDelete(id) {
            Swal.fire({
                title: 'Bạn có chắc chắn?',
                text: "Bài viết này sẽ bị xóa vĩnh viễn và không thể khôi phục!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ffc107',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Đồng ý xóa!',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteNews", "Admin")/' + id,
                        success: function () {
                            Swal.fire({ title: 'Đã xóa thành công!', text: 'Dữ liệu bài viết đã được loại bỏ khỏi hệ thống.', icon: 'success', confirmButtonColor: '#ffc107' }).then(() => {
                                window.location.reload();
                            });
                        },
                        error: function () {
                            Swal.fire('Lỗi hệ thống!', 'Không thể thực hiện xóa bài viết.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}